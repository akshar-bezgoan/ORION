      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <topic>/imu/data</topic>
      <gz_frame_id>imu_link</gz_frame_id>
      <imu>
        <angular_velocity>
          <x>
            <noise mean="0" stddev="0.001" type="gaussian"/>
          </x>
          <y>
            <noise mean="0" stddev="0.001" type="gaussian"/>
          </y>
          <z>
            <noise mean="0" stddev="0.001" type="gaussian"/>
          </z>
        </angular_velocity>
        <linear_acceleration>
          <x>
            <noise mean="0" stddev="0.01" type="gaussian"/>
          </x>
          <y>
            <noise mean="0" stddev="0.01" type="gaussian"/>
          </y>
          <z>
            <noise mean="0" stddev="0.01" type="gaussian"/>
          </z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>
