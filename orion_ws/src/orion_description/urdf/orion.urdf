<robot name="orion">
  <!-- ================= BASE LINK ================= -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.5 0.5 0.2"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>
  <!-- ================= SHOULDER LINK ================= -->
  <link name="shoulder_link">
    <inertial>
      <!-- Keep inertial at the link origin (IMPORTANT) -->
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="1"/>
      <!-- Inertia tensor must be relative to COM, not world -->
      <inertia ixx="0.05067488516" ixy="0.0" ixz="0.0" iyy="0.05067488516" iyz="0.0" izz="0.05968310366"/>
    </inertial>
    <visual>
      <!-- Position relative to the link -->
      <origin rpy="0 0 0" xyz="0 0 0.25"/>
      <geometry>
        <cylinder length="0.5" radius="0.3454941495"/>
      </geometry>
      <material name="cyan">
        <color rgba="0 1.0 1.0 1.0"/>
      </material>
    </visual>
  </link>
  <!-- ================= JOINT ================= -->
  <joint name="shoulder_joint" type="continuous">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <!-- Joint is at top of base -->
    <origin rpy="0 0 0" xyz="0 0 0.1"/>
    <axis xyz="0 0 1"/>
  </joint>
</robot>
