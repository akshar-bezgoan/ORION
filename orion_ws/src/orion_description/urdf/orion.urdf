  </link>
  <joint name="elbow_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.055"/>
    <axis xyz="0 1 0"/>
    <limit effort="5.0" lower="-1.57" upper="0.57" velocity="0.10"/>
    <dynamics damping="0.06" friction="0.08"/>
  </joint>
  <!--Forearm link-->
  <link name="forearm_link">
    <visual>
      <origin rpy="0 1.5707963267948966 0" xyz="0.06 0 0"/>
      <geometry>
        <cylinder length="0.12" radius="0.015"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <visual>
      <origin rpy="0 1.5707963267948966 0" xyz="0.12 0 0"/>
      <geometry>
        <cylinder length="0.015" radius="0.024"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin rpy="0 1.5707963267948966 0" xyz="0.06 0 0"/>
      <geometry>
        <cylinder length="0.12" radius="0.015"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.18"/>
      <origin rpy="0 0 0" xyz="0.06 0 0"/>
      <inertia ixx="2.0249999999999998e-05" ixy="0" ixz="0" iyy="0.00022612499999999998" iyz="0" izz="0.00022612499999999998"/>
    </inertial>
  </link>
  <joint name="wrist_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin rpy="0 0 0" xyz="0.15 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="5.0" lower="0.0" upper="2.7" velocity="0.10"/>
    <dynamics damping="0.04" friction="0.06"/>
  </joint>
  <!--Hand link-->
  <link name="hand_link">
    <visual>
      <origin rpy="0 1.5707963267948966 0" xyz="0.0275 0 0"/>
      <geometry>
        <cylinder length="0.055" radius="0.012"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin rpy="0 1.5707963267948966 0" xyz="0.0275 0 0"/>
      <geometry>
        <cylinder length="0.055" radius="0.012"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <origin rpy="0 0 0" xyz="0.0275 0 0"/>
      <inertia ixx="7.2000000000000005e-06" ixy="0" ixz="0" iyy="2.8808333333333333e-05" iyz="0" izz="2.8808333333333333e-05"/>
    </inertial>
  </link>
  <joint name="wrist_roll_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="hand_link"/>
    <origin rpy="0 0 0" xyz="0.12 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="5.0" lower="-1.0" upper="1.0" velocity="0.10"/>
    <dynamics damping="0.02" friction="0.03"/>
  </joint>
  <!--Gripper base link-->
  <link name="gripper_base_link">
    <visual>
      <origin rpy="0 1.5707963267948966 0" xyz="0.018 0 0"/>
      <geometry>
        <box size="0.028 0.052 0.018"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin rpy="0 1.5707963267948966 0" xyz="0.018 0 0"/>
      <geometry>
        <box size="0.028 0.052 0.018"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.06"/>
      <origin rpy="0 0 0" xyz="0.018 0 0"/>
      <inertia ixx="1.5139999999999997e-05" ixy="0" ixz="0" iyy="5.5399999999999995e-06" iyz="0" izz="1.7439999999999996e-05"/>
    </inertial>
  </link>
  <joint name="gripper_base_joint" type="fixed">
    <parent link="hand_link"/>
    <child link="gripper_base_link"/>
    <origin rpy="0 0 0" xyz="0.055 0 0"/>
  </joint>
  <!--Left gripper-->
  <link name="gripper_left_link">
    <visual>
      <origin rpy="0 1.5707963267948966 0" xyz="0.022 0 0"/>
      <geometry>
        <box size="0.044 0.009 0.014"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin rpy="0 1.5707963267948966 0" xyz="0.022 0 0"/>
      <geometry>
        <box size="0.044 0.009 0.014"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.03"/>
      <origin rpy="0 0 0" xyz="0.022 0 0"/>
      <inertia ixx="6.924999999999999e-07" ixy="0" ixz="0" iyy="5.329999999999999e-06" iyz="0" izz="5.042499999999999e-06"/>
    </inertial>
  </link>
  <joint name="gripper_left_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="gripper_left_link"/>
    <origin rpy="0 0 0" xyz="0 0.022 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="5.0" lower="0.0" upper="0.025" velocity="0.10"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>
  <!--Right gripper-->
  <link name="gripper_right_link">
    <visual>
      <origin rpy="0 1.5707963267948966 0" xyz="0.022 0 0"/>
      <geometry>
        <box size="0.044 0.009 0.014"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin rpy="0 1.5707963267948966 0" xyz="0.022 0 0"/>
      <geometry>
        <box size="0.044 0.009 0.014"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.03"/>
      <origin rpy="0 0 0" xyz="0.022 0 0"/>
      <inertia ixx="6.924999999999999e-07" ixy="0" ixz="0" iyy="5.329999999999999e-06" iyz="0" izz="5.042499999999999e-06"/>
    </inertial>
  </link>
  <joint name="gripper_right_joint" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="gripper_right_link"/>
    <origin rpy="0 0 0" xyz="0 -0.022 0"/>
    <axis xyz="0 -1 0"/>
    <limit effort="5.0" lower="0.0" upper="0.025" velocity="0.10"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>
  <!--TCP-->
  <link name="tcp_link"/>
  <joint name="tcp_joint" type="fixed">
    <parent link="gripper_base_link"/>
    <child link="tcp_link"/>
    <origin rpy="0 0 0" xyz="0.050 0 0"/>
  </joint>
  <!--Gazebo link colours-->
  <gazebo reference="shoulder_link">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="upper_arm_link">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="forearm_link">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="hand_link">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="gripper_base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="gripper_left_link">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="gripper_right_link">
    <material>Gazebo/Grey</material>
  </gazebo>
  <!--Gazebo joint friction-->
  <gazebo reference="shoulder_joint">
    <implicitSpringDamper>true</implicitSpringDamper>
    <provideFeedback>true</provideFeedback>
  </gazebo>
  <gazebo reference="elbow_joint">
    <implicitSpringDamper>true</implicitSpringDamper>
    <provideFeedback>true</provideFeedback>
  </gazebo>
  <gazebo reference="wrist_joint">
    <implicitSpringDamper>true</implicitSpringDamper>
    <provideFeedback>true</provideFeedback>
  </gazebo>
  <gazebo reference="wrist_roll_joint">
    <implicitSpringDamper>true</implicitSpringDamper>
    <provideFeedback>true</provideFeedback>
  </gazebo>
  <!--ROS2 Control plugin-->
  <ros2_control name="orion_arm" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="shoulder_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="elbow_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="wrist_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="wrist_roll_joint">
      <command_interface name="position"/>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="gripper_left_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">0.025</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="gripper_right_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">0.025</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
  <!--GZ Sensor activation system-->
  <gazebo>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu"/>
  </gazebo>
</robot>
