<?xml version="1.0"?>
<robot name="orion"
       xmlns:xacro="http://www.ros.org/wiki/xacro"
       xmlns:gz="http://gazebosim.org/schema">
  <xacro:arg name="controllers_file" default="config/ros2_controllers.yaml"/>

<!--CONSTANTS-->
  <xacro:property name="base_x"    value="0.320"/> 
  <xacro:property name="base_y"    value="0.350"/> 
  <xacro:property name="base_z"    value="0.080"/> 
  <xacro:property name="base_mass" value="3.5"/>    

  <xacro:property name="wheel_radius" value="0.050"/>              
  <xacro:property name="wheel_width"  value="0.040"/>              
  <xacro:property name="wheel_mass"   value="0.3"/>                
  <xacro:property name="wheel_x_off"  value="0.112"/>             
  <xacro:property name="wheel_y_off"  value="0.195"/>              
  <xacro:property name="wheel_z_off"  value="${-base_z/2.0}"/>     
  <xacro:property name="wheel_mu"     value="1.0"/>                
  <xacro:property name="wheel_mu2"    value="0.001"/>              

  <xacro:property name="mast_r"  value="0.010"/>   
  <xacro:property name="mast_h"  value="0.300"/>   
  <xacro:property name="mast_x"  value="0.000"/>   
  <xacro:property name="mast_y"  value="0.000"/>   
  <xacro:property name="lidar_r" value="0.038"/>  
  <xacro:property name="lidar_h" value="0.041"/>   
  <xacro:property name="lidar_m" value="0.185"/>   
  <xacro:property name="imu_xyz" value="0.02"/>  
  <xacro:property name="shoulder_mount_x" value="${base_x/2.0 - r_shoulder - 0.006}"/>  
  <xacro:property name="shoulder_mount_z" value="${base_z/2.0}"/>        

  <xacro:property name="shoulder_h"   value="0.050"/>  
  <xacro:property name="upper_arm_l"  value="0.220"/>  
  <xacro:property name="forearm_l"    value="0.145"/>  
  <xacro:property name="gripper_l"    value="0.055"/>  
  <xacro:property name="gripper_tcp"  value="0.050"/>  

  <xacro:property name="r_shoulder"  value="0.020"/>
  <xacro:property name="r_upper_arm" value="0.018"/>
  <xacro:property name="r_forearm"   value="0.015"/>
  <xacro:property name="r_gripper"   value="0.012"/>

  <xacro:property name="m_shoulder"  value="0.300"/>
  <xacro:property name="m_upper_arm" value="0.308"/>
  <xacro:property name="m_forearm"   value="0.199"/>
  <xacro:property name="m_gripper"   value="0.120"/>  

  <xacro:property name="shoulder_lo"  value="-1.58"/>  
  <xacro:property name="shoulder_hi"  value="0.79"/>  
  <xacro:property name="elbow_lo"     value="-0.25"/>  
  <xacro:property name="elbow_hi"     value=" 1.57"/>  
  <xacro:property name="wrist_lo"     value=" 0.00"/>  
  <xacro:property name="wrist_hi"     value=" 2.70"/>  

  <xacro:property name="gp_lo"  value="-1.57"/>
  <xacro:property name="gp_hi"  value=" 1.57"/>
  <xacro:property name="gy_lo"  value="-1.57"/>
  <xacro:property name="gy_hi"  value=" 1.57"/>
  <xacro:property name="gr_lo"  value="-1.57"/>
  <xacro:property name="gr_hi"  value=" 1.57"/>

  <xacro:property name="shoulder_damp"  value="0.08"/>  <xacro:property name="shoulder_fric" value="0.10"/>
  <xacro:property name="elbow_damp"     value="0.06"/>  <xacro:property name="elbow_fric"    value="0.08"/>
  <xacro:property name="wrist_damp"     value="0.04"/>  <xacro:property name="wrist_fric"    value="0.06"/>
  <xacro:property name="gripper_damp"   value="0.02"/>  <xacro:property name="gripper_fric"  value="0.03"/>

  <xacro:property name="arm_effort"    value="5.0"/>   
  <xacro:property name="arm_vel"       value="1.0"/>   
  <xacro:property name="gripper_effort" value="5.0"/>  
  <xacro:property name="gripper_vel"    value="0.10"/> 
  <xacro:property name="gripper_stroke" value="0.025"/>

  <xacro:property name="finger_w"         value="0.012"/>  
  <xacro:property name="finger_h"         value="0.018"/>  
  <xacro:property name="finger_jaw_l"     value="0.055"/>  
  <xacro:property name="finger_jaw_w"     value="0.020"/>  
  <xacro:property name="finger_bracket_l" value="0.018"/>  
  <xacro:property name="finger_bracket_w" value="0.028"/>  


<!--colours-->
  <material name="grey">      <color rgba="0.60 0.60 0.60 1.0"/></material>
  <material name="dark_grey"> <color rgba="0.25 0.25 0.25 1.0"/></material>
  <material name="black">     <color rgba="0.08 0.08 0.08 1.0"/></material>
  <material name="white">     <color rgba="0.90 0.90 0.90 1.0"/></material>
  <material name="red">       <color rgba="0.80 0.10 0.10 1.0"/></material>
  <material name="blue">      <color rgba="0.10 0.10 0.80 1.0"/></material>
  <material name="green">     <color rgba="0.10 0.70 0.10 1.0"/></material>
  <material name="orange">    <color rgba="1.00 0.45 0.00 1.0"/></material>
  <material name="yellow">    <color rgba="1.00 0.85 0.00 1.0"/></material>

  <xacro:macro name="gz_material" params="link gz_mat">
    <gazebo reference="${link}">
      <material>${gz_mat}</material>
    </gazebo>
  </xacro:macro>


<!--inertia macro-->
  <xacro:macro name="inertia_cyl_z" params="m r l">
    <inertial>
      <mass value="${m}"/>
      <origin xyz="0 0 ${l/2.0}" rpy="0 0 0"/>
      <inertia
        ixx="${(1.0/12.0)*m*(3.0*r*r + l*l)}"
        iyy="${(1.0/12.0)*m*(3.0*r*r + l*l)}"
        izz="${0.5*m*r*r}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="inertia_cyl_x" params="m r l">
    <inertial>
      <mass value="${m}"/>
      <origin xyz="${l/2.0} 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${0.5*m*r*r}"
        iyy="${(1.0/12.0)*m*(3.0*r*r + l*l)}"
        izz="${(1.0/12.0)*m*(3.0*r*r + l*l)}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="inertia_box" params="m x y z ox oy oz">
    <inertial>
      <mass value="${m}"/>
      <origin xyz="${ox} ${oy} ${oz}" rpy="0 0 0"/>
      <inertia
        ixx="${(1.0/12.0)*m*(y*y+z*z)}"
        iyy="${(1.0/12.0)*m*(x*x+z*z)}"
        izz="${(1.0/12.0)*m*(x*x+y*y)}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="inertia_point" params="m">
    <inertial>
      <mass value="${m}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

<!--base macros-->
  <xacro:macro name="base">
    <link name="base_link">

      <!-- outer shell -->
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><box size="${base_x} ${base_y} ${base_z}"/></geometry>
        <material name="dark_grey"/>
      </visual>
      <!-- upper plate -->
      <visual>
        <origin xyz="0 0 ${base_z/2.0 - 0.004}" rpy="0 0 0"/>
        <geometry><box size="${base_x - 0.006} ${base_y - 0.006} 0.006"/></geometry>
        <material name="grey"/>
      </visual>
      <!-- battery layer -->
      <visual>
        <origin xyz="-0.050 0 ${-base_z/2.0 + 0.0175}" rpy="0 0 0"/>
        <geometry><box size="${base_x*0.55} ${base_y - 0.030} 0.033"/></geometry>
        <material name="black"/>
      </visual>
      <!-- motor driver layer -->
      <visual>
        <origin xyz="-0.04 0 ${-base_z/2.0 + 0.048}" rpy="0 0 0"/>
        <geometry><box size="${base_x*0.45} ${base_y - 0.030} 0.018"/></geometry>
        <material name="dark_grey"/>
      </visual>
      <!-- power layer -->
      <visual>
        <origin xyz="0 0 ${-base_z/2.0 + 0.068}" rpy="0 0 0"/>
        <geometry><box size="${base_x - 0.020} ${base_y - 0.030} 0.016"/></geometry>
        <material name="dark_grey"/>
      </visual>
      <!--pi pcb-->
      <visual>
        <origin xyz="-0.07 0.03 ${-base_z/2.0 + 0.060}" rpy="0 0 0"/>
        <geometry><box size="0.085 0.056 0.004"/></geometry>
        <material name="green"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><box size="${base_x} ${base_y} ${base_z}"/></geometry>
      </collision>

      <inertial>
        <mass value="${base_mass}"/>
        <origin xyz="-0.056 0 0" rpy="0 0 0"/>
        <inertia
          ixx="${(1.0/12.0)*base_mass*(base_y*base_y + base_z*base_z)}"
          iyy="${(1.0/12.0)*base_mass*(base_x*base_x + base_z*base_z)}"
          izz="${(1.0/12.0)*base_mass*(base_x*base_x + base_y*base_y)}"
          ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <gazebo reference="base_link">
      <collision>
        <surface>
          <friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction>
        </surface>
      </collision>
    </gazebo>

    <gazebo>
      <plugin filename="libgz_ros2_control-system.so"
              name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>$(arg controllers_file)</parameters>
        <robot_param>robot_description</robot_param>
        <robot_param_node>robot_state_publisher</robot_param_node>
      </plugin>
    </gazebo>
  </xacro:macro>

<!--mecanum wheel macro-->
  <xacro:macro name="mecanum_wheel" params="name x_sign y_sign fdir1_y mu_val">
    <link name="${name}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="black"/>
      </visual>
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="${wheel_radius*0.38}" length="${wheel_width+0.002}"/></geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="${wheel_radius}"/></geometry>
      </collision>
      <inertial>
        <mass value="${wheel_mass}"/>
        <origin xyz="0 0 0"/>
        <inertia
          ixx="${(1.0/12.0)*wheel_mass*(3.0*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
          iyy="${0.5*wheel_mass*wheel_radius*wheel_radius}"
          izz="${(1.0/12.0)*wheel_mass*(3.0*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
          ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_wheel_link"/>
      <origin xyz="${x_sign*wheel_x_off} ${y_sign*wheel_y_off} ${wheel_z_off}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.01" friction="0.01"/>
    </joint>

    <gazebo reference="${name}_wheel_link">
      <collision>
        <surface>
          <friction>
            <ode>
              <mu>${mu_val}</mu>
              <mu2>${wheel_mu2}</mu2>
              <fdir1 gz:expressed_in="base_link">1 ${fdir1_y} 0</fdir1>
            </ode>
          </friction>
          <contact>
            <ode>
              <kp>500000.0</kp>
              <kd>100.0</kd>
              <min_depth>0.001</min_depth>
              <max_vel>0.1</max_vel>
            </ode>
          </contact>
        </surface>
      </collision>
    </gazebo>
  </xacro:macro>

  <xacro:macro name="wheels">
    <xacro:mecanum_wheel name="front_left"  x_sign=" 1" y_sign=" 1" fdir1_y=" 1" mu_val="1.0"/>
    <xacro:mecanum_wheel name="front_right" x_sign=" 1" y_sign="-1" fdir1_y="-1" mu_val="1.0"/>
    <xacro:mecanum_wheel name="rear_left"   x_sign="-1" y_sign=" 1" fdir1_y="-1" mu_val="1.0"/>
    <xacro:mecanum_wheel name="rear_right"  x_sign="-1" y_sign="-1" fdir1_y=" 1" mu_val="1.0"/>
  </xacro:macro>


  <!--sensor macros-->
  <xacro:macro name="sensors">

    <!-- lidar mast -->
    <link name="lidar_mast_link">
      <visual>
        <origin xyz="0 0 ${mast_h/2.0}" rpy="0 0 0"/>
        <geometry><cylinder radius="${mast_r}" length="${mast_h}"/></geometry>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${mast_h/2.0}" rpy="0 0 0"/>
        <geometry><cylinder radius="${mast_r}" length="${mast_h}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.080"/>
        <origin xyz="0 0 ${mast_h/2.0}" rpy="0 0 0"/>
        <inertia
          ixx="${(1.0/12.0)*0.080*(3.0*mast_r*mast_r + mast_h*mast_h)}"
          iyy="${(1.0/12.0)*0.080*(3.0*mast_r*mast_r + mast_h*mast_h)}"
          izz="${0.5*0.080*mast_r*mast_r}"
          ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="lidar_mast_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="lidar_mast_link"/>
      <origin xyz="${mast_x} ${mast_y} ${base_z/2.0}" rpy="0 0 0"/>
    </joint>

    <!--lidar-->
    <link name="lidar_link">
      <visual>
        <origin xyz="0 0 ${lidar_h/2.0}" rpy="0 0 0"/>
        <geometry><cylinder radius="${lidar_r}" length="${lidar_h}"/></geometry>
        <material name="black"/>
      </visual>
      <visual>
        <origin xyz="0 0 ${lidar_h + 0.009}" rpy="0 0 0"/>
        <geometry><cylinder radius="${lidar_r - 0.006}" length="0.018"/></geometry>
        <material name="dark_grey"/>
      </visual>
      <visual>
        <origin xyz="${lidar_r - 0.003} 0 ${lidar_h/2.0}" rpy="0 0 0"/>
        <geometry><box size="0.004 0.012 ${lidar_h*0.5}"/></geometry>
        <material name="blue"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${lidar_h/2.0}" rpy="0 0 0"/>
        <geometry><cylinder radius="${lidar_r}" length="${lidar_h}"/></geometry>
      </collision>
      <inertial>
        <mass value="${lidar_m}"/>
        <origin xyz="0 0 ${lidar_h/2.0}" rpy="0 0 0"/>
        <inertia
          ixx="${(1.0/12.0)*lidar_m*(3.0*lidar_r*lidar_r + lidar_h*lidar_h)}"
          iyy="${(1.0/12.0)*lidar_m*(3.0*lidar_r*lidar_r + lidar_h*lidar_h)}"
          izz="${0.5*lidar_m*lidar_r*lidar_r}"
          ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="lidar_joint" type="fixed">
      <parent link="lidar_mast_link"/>
      <child  link="lidar_link"/>
      <origin xyz="0 0 ${mast_h}" rpy="0 0 0"/>
    </joint>

    <gazebo reference="lidar_link">
      <sensor name="lidar" type="gpu_lidar">
        <topic>scan</topic>
        <update_rate>10</update_rate>
        <lidar>
          <scan>
            <horizontal>
              <samples>360</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159</min_angle>
              <max_angle> 3.14159</max_angle>
            </horizontal>
          </scan>
          <range>
            <min>0.12</min>
            <max>12.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise><type>gaussian</type><mean>0.0</mean><stddev>0.01</stddev></noise>
        </lidar>
        <always_on>true</always_on>
        <visualize>false</visualize>
        <gz_frame_id>lidar_link</gz_frame_id>
      </sensor>
    </gazebo>

    <!-- IMU -->
    <link name="imu_link">
      <visual>
        <origin xyz="0 0 0"/>
        <geometry><box size="${imu_xyz} ${imu_xyz} ${imu_xyz}"/></geometry>
        <material name="dark_grey"/>
      </visual>
      <inertial>
        <mass value="0.05"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="imu_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="imu_link"/>
      <origin xyz="0 0 ${base_z}" rpy="0 0 0"/>
    </joint>

    <gazebo reference="imu_link">
      <sensor name="imu" type="imu">
        <topic>imu/data</topic>
        <update_rate>100</update_rate>
        <always_on>true</always_on>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></x>
            <y><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></y>
            <z><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></z>
          </linear_acceleration>
        </imu>
        <gz_frame_id>imu_link</gz_frame_id>
      </sensor>
    </gazebo>

  </xacro:macro>


  <!--arm marco-->
  <xacro:macro name="arm">
    <link name="shoulder_link">
      <visual>
        <origin xyz="${shoulder_h/2.0} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry><cylinder radius="${r_shoulder}" length="${shoulder_h}"/></geometry>
        <material name="grey"/>
      </visual>
      <visual>  
        <origin xyz="0.010 0 0" rpy="0 ${pi/2} 0"/>
        <geometry><cylinder radius="${r_shoulder*1.9}" length="0.020"/></geometry>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <origin xyz="${shoulder_h/2.0} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry><cylinder radius="${r_shoulder}" length="${shoulder_h}"/></geometry>
      </collision>
      <xacro:inertia_cyl_x m="${m_shoulder}" r="${r_shoulder}" l="${shoulder_h}"/>
    </link>

    <joint name="shoulder_joint" type="revolute">
      <parent link="base_link"/>
      <child  link="shoulder_link"/>
      <origin xyz="${shoulder_mount_x} 0 ${shoulder_mount_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${shoulder_lo}" upper="${shoulder_hi}"
             effort="${arm_effort}" velocity="${arm_vel}"/>
      <dynamics damping="${shoulder_damp}" friction="${shoulder_fric}"/>
    </joint>

    <link name="upper_arm_link">
      <visual>
        <origin xyz="${upper_arm_l/2.0} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry><cylinder radius="${r_upper_arm}" length="${upper_arm_l}"/></geometry>
        <material name="grey"/>
      </visual>
      <visual>  
        <origin xyz="${upper_arm_l} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry><cylinder radius="${r_upper_arm*1.7}" length="0.018"/></geometry>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <origin xyz="${upper_arm_l/2.0} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry><cylinder radius="${r_upper_arm}" length="${upper_arm_l}"/></geometry>
      </collision>
      <xacro:inertia_cyl_x m="${m_upper_arm}" r="${r_upper_arm}" l="${upper_arm_l}"/>
    </link>

    <joint name="elbow_joint" type="revolute">
      <parent link="shoulder_link"/>
      <child  link="upper_arm_link"/>
      <origin xyz="${shoulder_h} 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${elbow_lo}" upper="${elbow_hi}"
             effort="${arm_effort}" velocity="${arm_vel}"/>
      <dynamics damping="${elbow_damp}" friction="${elbow_fric}"/>
    </joint>

    <link name="forearm_link">
      <visual>
        <origin xyz="${forearm_l/2.0} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry><cylinder radius="${r_forearm}" length="${forearm_l}"/></geometry>
        <material name="grey"/>
      </visual>
      <visual>  
        <origin xyz="${forearm_l} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry><cylinder radius="${r_forearm*1.6}" length="0.015"/></geometry>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <origin xyz="${forearm_l/2.0} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry><cylinder radius="${r_forearm}" length="${forearm_l}"/></geometry>
      </collision>
      <xacro:inertia_cyl_x m="${m_forearm}" r="${r_forearm}" l="${forearm_l}"/>
    </link>

    <joint name="wrist_joint" type="revolute">
      <parent link="upper_arm_link"/>
      <child  link="forearm_link"/>
      <origin xyz="${upper_arm_l} 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${wrist_lo}" upper="${wrist_hi}"
             effort="${arm_effort}" velocity="${arm_vel}"/>
      <dynamics damping="${wrist_damp}" friction="${wrist_fric}"/>
    </joint>

    <link name="gripper_pitch_link">
      <xacro:inertia_point m="0.001"/>
    </link>

    <joint name="gripper_pitch_joint" type="revolute">
      <parent link="forearm_link"/>
      <child  link="gripper_pitch_link"/>
      <origin xyz="${forearm_l} 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${gp_lo}" upper="${gp_hi}"
             effort="${arm_effort}" velocity="${arm_vel}"/>
      <dynamics damping="${gripper_damp}" friction="${gripper_fric}"/>
    </joint>

    <link name="gripper_yaw_link">
      <xacro:inertia_point m="0.001"/>
    </link>

    <joint name="gripper_yaw_joint" type="revolute">
      <parent link="gripper_pitch_link"/>
      <child  link="gripper_yaw_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="${gy_lo}" upper="${gy_hi}"
             effort="${arm_effort}" velocity="${arm_vel}"/>
      <dynamics damping="${gripper_damp}" friction="${gripper_fric}"/>
    </joint>

    <link name="gripper_roll_link">
      <xacro:inertia_point m="0.001"/>
    </link>

    <joint name="gripper_roll_joint" type="revolute">
      <parent link="gripper_yaw_link"/>
      <child  link="gripper_roll_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>  
      <axis xyz="1 0 0"/>
      <limit lower="${gr_lo}" upper="${gr_hi}"
             effort="${arm_effort}" velocity="${arm_vel}"/>
      <dynamics damping="${gripper_damp}" friction="${gripper_fric}"/>
    </joint>

    <link name="gripper_base_link">
      <visual>
        <origin xyz="${gripper_l/2.0} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry><box size="${gripper_l} 0.052 0.018"/></geometry>
        <material name="dark_grey"/>
      </visual>
      <collision>
        <origin xyz="${gripper_l/2.0} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry><box size="${gripper_l} 0.052 0.018"/></geometry>
      </collision>
      <xacro:inertia_box m="${m_gripper*0.5}" x="${gripper_l}" y="0.052" z="0.018"
                         ox="${gripper_l/2.0}" oy="0" oz="0"/>
    </link>
    <joint name="gripper_base_joint" type="fixed">
      <parent link="gripper_roll_link"/>
      <child  link="gripper_base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>
    <link name="gripper_left_link">
      <visual>
        <origin xyz="${gripper_l/2.0} 0 0" rpy="0 0 0"/>
        <geometry><box size="${gripper_l} ${finger_w} ${finger_h}"/></geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="${gripper_l/2.0} 0 0" rpy="0 0 0"/>
        <geometry><box size="${gripper_l} ${finger_w} ${finger_h}"/></geometry>
      </collision>
      <visual>
        <origin xyz="${gripper_l + finger_jaw_l/2.0} ${-(finger_jaw_w - finger_w)/2.0} 0" rpy="0 0 0"/>
        <geometry><box size="${finger_jaw_l} ${finger_jaw_w} ${finger_h}"/></geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="${gripper_l + finger_jaw_l/2.0} ${-(finger_jaw_w - finger_w)/2.0} 0" rpy="0 0 0"/>
        <geometry><box size="${finger_jaw_l} ${finger_jaw_w} ${finger_h}"/></geometry>
      </collision>
      <visual>
        <origin xyz="${-finger_bracket_l/2.0} ${-(finger_bracket_w - finger_w)/2.0} 0" rpy="0 0 0"/>
        <geometry><box size="${finger_bracket_l} ${finger_bracket_w} ${finger_h}"/></geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="${-finger_bracket_l/2.0} ${-(finger_bracket_w - finger_w)/2.0} 0" rpy="0 0 0"/>
        <geometry><box size="${finger_bracket_l} ${finger_bracket_w} ${finger_h}"/></geometry>
      </collision>
      <xacro:inertia_box m="${m_gripper*0.25}" x="${gripper_l + finger_jaw_l}" y="${finger_jaw_w}" z="${finger_h}"
                         ox="${(gripper_l + finger_jaw_l)/2.0}" oy="0" oz="0"/>
    </link>

    <joint name="gripper_left_joint" type="prismatic">
      <parent link="gripper_base_link"/>
      <child  link="gripper_left_link"/>
      <origin xyz="0 ${0.052/2.0 - finger_w/2.0} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="0.0" upper="${gripper_stroke}"
             effort="${gripper_effort}" velocity="${gripper_vel}"/>
      <dynamics damping="0.01" friction="0.01"/>
    </joint>

    <link name="gripper_right_link">
      <visual>
        <origin xyz="${gripper_l/2.0} 0 0" rpy="0 0 0"/>
        <geometry><box size="${gripper_l} ${finger_w} ${finger_h}"/></geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="${gripper_l/2.0} 0 0" rpy="0 0 0"/>
        <geometry><box size="${gripper_l} ${finger_w} ${finger_h}"/></geometry>
      </collision>
      <visual>
        <origin xyz="${gripper_l + finger_jaw_l/2.0} ${(finger_jaw_w - finger_w)/2.0} 0" rpy="0 0 0"/>
        <geometry><box size="${finger_jaw_l} ${finger_jaw_w} ${finger_h}"/></geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="${gripper_l + finger_jaw_l/2.0} ${(finger_jaw_w - finger_w)/2.0} 0" rpy="0 0 0"/>
        <geometry><box size="${finger_jaw_l} ${finger_jaw_w} ${finger_h}"/></geometry>
      </collision>
      <visual>
        <origin xyz="${-finger_bracket_l/2.0} ${(finger_bracket_w - finger_w)/2.0} 0" rpy="0 0 0"/>
        <geometry><box size="${finger_bracket_l} ${finger_bracket_w} ${finger_h}"/></geometry>
        <material name="grey"/>
      </visual>
      <collision>
        <origin xyz="${-finger_bracket_l/2.0} ${(finger_bracket_w - finger_w)/2.0} 0" rpy="0 0 0"/>
        <geometry><box size="${finger_bracket_l} ${finger_bracket_w} ${finger_h}"/></geometry>
      </collision>
      <xacro:inertia_box m="${m_gripper*0.25}" x="${gripper_l + finger_jaw_l}" y="${finger_jaw_w}" z="${finger_h}"
                         ox="${(gripper_l + finger_jaw_l)/2.0}" oy="0" oz="0"/>
    </link>

    <joint name="gripper_right_joint" type="prismatic">
      <parent link="gripper_base_link"/>
      <child  link="gripper_right_link"/>
      <origin xyz="0 ${-(0.052/2.0 - finger_w/2.0)} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${-gripper_stroke}" upper="0.0"
             effort="${gripper_effort}" velocity="${gripper_vel}"/>
      <dynamics damping="0.01" friction="0.01"/>
      <mimic joint="gripper_left_joint" multiplier="-1" offset="0"/>
    </joint>

    <link name="tcp_link"/>
    <joint name="tcp_joint" type="fixed">
      <parent link="gripper_base_link"/>
      <child  link="tcp_link"/>
      <origin xyz="${gripper_tcp} 0 0" rpy="0 0 0"/>
    </joint>

  </xacro:macro>

  <!--ros2_control-->
  <ros2_control name="OrionSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="front_left_wheel_joint">
      <command_interface name="velocity"><param name="min">-50.0</param><param name="max">50.0</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/>
    </joint>
    <joint name="front_right_wheel_joint">
      <command_interface name="velocity"><param name="min">-50.0</param><param name="max">50.0</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/>
    </joint>
    <joint name="rear_left_wheel_joint">
      <command_interface name="velocity"><param name="min">-50.0</param><param name="max">50.0</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/>
    </joint>
    <joint name="rear_right_wheel_joint">
      <command_interface name="velocity"><param name="min">-50.0</param><param name="max">50.0</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/>
    </joint>

    <joint name="shoulder_joint">
      <command_interface name="position"><param name="min">${shoulder_lo}</param><param name="max">${shoulder_hi}</param></command_interface>
      <command_interface name="effort"><param name="min">-${arm_effort}</param><param name="max">${arm_effort}</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
    <joint name="elbow_joint">
      <command_interface name="position"><param name="min">${elbow_lo}</param><param name="max">${elbow_hi}</param></command_interface>
      <command_interface name="effort"><param name="min">-${arm_effort}</param><param name="max">${arm_effort}</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
    <joint name="wrist_joint">
      <command_interface name="position"><param name="min">${wrist_lo}</param><param name="max">${wrist_hi}</param></command_interface>
      <command_interface name="effort"><param name="min">-${arm_effort}</param><param name="max">${arm_effort}</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>

    <joint name="gripper_pitch_joint">
      <command_interface name="position"><param name="min">${gp_lo}</param><param name="max">${gp_hi}</param></command_interface>
      <command_interface name="effort"><param name="min">-${arm_effort}</param><param name="max">${arm_effort}</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
    <joint name="gripper_yaw_joint">
      <command_interface name="position"><param name="min">${gy_lo}</param><param name="max">${gy_hi}</param></command_interface>
      <command_interface name="effort"><param name="min">-${arm_effort}</param><param name="max">${arm_effort}</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>
    <joint name="gripper_roll_joint">
      <command_interface name="position"><param name="min">${gr_lo}</param><param name="max">${gr_hi}</param></command_interface>
      <command_interface name="effort"><param name="min">-${arm_effort}</param><param name="max">${arm_effort}</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/><state_interface name="effort"/>
    </joint>

    <joint name="gripper_left_joint">
      <command_interface name="position"><param name="min">0.0</param><param name="max">${gripper_stroke}</param></command_interface>
      <state_interface name="position"/><state_interface name="velocity"/>
    </joint>
    <joint name="gripper_right_joint">
      <param name="mimic">gripper_left_joint</param>
      <param name="multiplier">-1</param>
      <state_interface name="position"/><state_interface name="velocity"/>
    </joint>

  </ros2_control>

  <!--Call-->
  <xacro:base/>
  <xacro:wheels/>
  <xacro:sensors/>
  <xacro:arm/>

</robot>
