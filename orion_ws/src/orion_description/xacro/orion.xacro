<?xml version="1.0"?>
<robot name="orion" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================= BASE LINK ================= -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.5 0.5 0.2"/>
      </geometry>

      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
  </link>

  <!-- ================= SHOULDER LINK ================= -->
  <link name="shoulder_link">

    <inertial>
      <!-- Keep inertial at the link origin (IMPORTANT) -->
      <origin xyz="0 0 0" rpy="0 0 0"/>

      <mass value="1"/>

      <!-- Inertia tensor must be relative to COM, not world -->
      <inertia
        ixx="0.05067488516"
        iyy="0.05067488516"
        izz="0.05968310366"
        ixy="0.0"
        ixz="0.0"
        iyz="0.0"/>
    </inertial>

    <visual>
      <!-- Position relative to the link -->
      <origin xyz="0 0 0.25" rpy="0 0 0"/>

      <geometry>
        <cylinder radius="0.3454941495" length="0.5"/>
      </geometry>

      <material name="cyan">
        <color rgba="0 1.0 1.0 1.0"/>
      </material>
    </visual>

  </link>

  <!-- ================= JOINT ================= -->
  <joint name="shoulder_joint" type="continuous">
    <parent link="base_link"/>
    <child link="shoulder_link"/>

    <!-- Joint is at top of base -->
    <origin xyz="0 0 0.1" rpy="0 0 0"/>

    <axis xyz="0 0 1"/>
  </joint>

</robot>