<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================================================================
       ORION BASE  —  Model 2 dimensions
         280 mm (x, front-back)  ×  320 mm (y, left-right)  ×  105 mm (z)
       Layered internals: Battery → Drivers → Power/ESP32 → Pi5 → Top plate
       ================================================================ -->

  <xacro:property name="base_x"     value="0.280"/>
  <xacro:property name="base_y"     value="0.320"/>
  <xacro:property name="base_z"     value="0.105"/>
  <xacro:property name="base_mass"  value="3.5"/>

  <!-- Wheel params needed to compute base_link height above ground -->
  <xacro:property name="wheel_radius" value="0.050"/>

  <!-- base_link sits at wheel_radius + half chassis height above the ground -->
  <xacro:property name="base_link_z" value="${wheel_radius + base_z / 2.0}"/>

  <xacro:macro name="base">

    <!-- ── Ground reference frame (no geometry / no inertia) ── -->
    <link name="base_footprint"/>

    <joint name="base_footprint_joint" type="fixed">
      <parent link="base_footprint"/>
      <child  link="base_link"/>
      <origin xyz="0 0 ${base_link_z}" rpy="0 0 0"/>
    </joint>

    <!-- ── Main chassis ── -->
    <link name="base_link">

      <!-- Outer shell -->
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><box size="${base_x} ${base_y} ${base_z}"/></geometry>
        <material name="dark_grey"/>
      </visual>

      <!-- Top plate (slightly proud) -->
      <visual>
        <origin xyz="0 0 ${base_z/2.0 - 0.004}" rpy="0 0 0"/>
        <geometry><box size="${base_x - 0.006} ${base_y - 0.006} 0.006"/></geometry>
        <material name="grey"/>
      </visual>

      <!-- Layer 1 – Battery (bottom, tallest) -->
      <visual>
        <origin xyz="0 0 ${-base_z/2.0 + 0.0175}" rpy="0 0 0"/>
        <geometry><box size="${base_x - 0.020} ${base_y - 0.030} 0.033"/></geometry>
        <material name="black"/>
      </visual>

      <!-- Layer 2 – Motor Drivers -->
      <visual>
        <origin xyz="-0.04 0 ${-base_z/2.0 + 0.048}" rpy="0 0 0"/>
        <geometry><box size="${base_x*0.45} ${base_y - 0.030} 0.018"/></geometry>
        <material name="dark_grey"/>
      </visual>

      <!-- Layer 3 – Power distribution + ESP32 -->
      <visual>
        <origin xyz="0 0 ${-base_z/2.0 + 0.068}" rpy="0 0 0"/>
        <geometry><box size="${base_x - 0.020} ${base_y - 0.030} 0.016"/></geometry>
        <material name="dark_grey"/>
      </visual>

      <!-- Layer 4 – Raspberry Pi 5 (green PCB) -->
      <visual>
        <origin xyz="-0.03 0.03 ${-base_z/2.0 + 0.088}" rpy="0 0 0"/>
        <geometry><box size="0.085 0.056 0.004"/></geometry>
        <material name="green"/>
      </visual>

      <!-- Arm mount boss on top-centre -->
      <visual>
        <origin xyz="0.0 0.0 ${base_z/2.0 + 0.012}" rpy="0 0 0"/>
        <geometry><cylinder radius="0.032" length="0.024"/></geometry>
        <material name="black"/>
      </visual>

      <!-- Collision uses the full bounding box only -->
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><box size="${base_x} ${base_y} ${base_z}"/></geometry>
      </collision>

      <inertial>
        <mass value="${base_mass}"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <!-- Box inertia  I = (1/12) m (a² + b²) -->
        <inertia
          ixx="${(1.0/12.0) * base_mass * (base_y*base_y + base_z*base_z)}"
          iyy="${(1.0/12.0) * base_mass * (base_x*base_x + base_z*base_z)}"
          izz="${(1.0/12.0) * base_mass * (base_x*base_x + base_y*base_y)}"
          ixy="0" ixz="0" iyz="0"/>
      </inertial>

    </link>

  </xacro:macro>

</robot>
