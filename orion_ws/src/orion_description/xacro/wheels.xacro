<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================================================================
       ORION MECANUM WHEELS  —  4-wheel omnidirectional drive
         wheel_radius : 50 mm  (standard 100 mm diameter mecanum)
         wheel_width  : 40 mm
         Positioned at four corners of the 280 × 320 mm chassis
       ================================================================ -->

  <xacro:property name="wheel_radius"  value="0.050"/>
  <xacro:property name="wheel_width"   value="0.040"/>
  <xacro:property name="wheel_mass"    value="0.300"/>

  <xacro:property name="base_z"        value="0.105"/>

  <!-- Wheel centre offsets relative to base_link origin (centre of chassis) -->
  <xacro:property name="wheel_x_off"  value="0.095"/>   <!-- ±95 mm front/rear  -->
  <xacro:property name="wheel_y_off"  value="0.130"/>   <!-- ±130 mm left/right -->
  <!-- Wheel centres flush with bottom of chassis -->
  <xacro:property name="wheel_z_off"  value="${-base_z / 2.0}"/>

  <!-- Roller stripe count (visual only) -->
  <xacro:property name="roller_count"  value="9"/>

  <!-- ── Single mecanum wheel ── -->
  <xacro:macro name="mecanum_wheel" params="name x_sign y_sign roller_sign">

    <link name="${name}_wheel_link">

      <!-- Main tyre body -->
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>

      <!-- Hub (lighter centre) -->
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius * 0.38}" length="${wheel_width + 0.002}"/>
        </geometry>
        <material name="grey"/>
      </visual>

      <!-- Axle stub (left side) -->
      <visual>
        <origin xyz="0  ${wheel_width/2.0 + 0.006} 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="0.008" length="0.012"/></geometry>
        <material name="dark_grey"/>
      </visual>

      <!-- Axle stub (right side) -->
      <visual>
        <origin xyz="0 ${-(wheel_width/2.0 + 0.006)} 0" rpy="${pi/2} 0 0"/>
        <geometry><cylinder radius="0.008" length="0.012"/></geometry>
        <material name="dark_grey"/>
      </visual>

      <!-- Collision is a simple cylinder -->
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>

      <!-- Cylinder inertia about Y (spin axis):
             Ixx = Izz = (1/12) m (3r² + h²)      (h = wheel_width here)
             Iyy         = (1/2) m r²   ← spin axis -->
      <inertial>
        <mass value="${wheel_mass}"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia
          ixx="${(1.0/12.0) * wheel_mass * (3.0*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
          iyy="${0.5         * wheel_mass * wheel_radius * wheel_radius}"
          izz="${(1.0/12.0) * wheel_mass * (3.0*wheel_radius*wheel_radius + wheel_width*wheel_width)}"
          ixy="0" ixz="0" iyz="0"/>
      </inertial>

    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_wheel_link"/>
      <origin xyz="${x_sign * wheel_x_off}
                   ${y_sign * wheel_y_off}
                   ${wheel_z_off}"
              rpy="0 0 0"/>
      <!-- Mecanum wheels spin about the Y axis -->
      <axis xyz="0 1 0"/>
      <dynamics damping="0.01" friction="0.05"/>
    </joint>

  </xacro:macro>

  <!-- ================================================================
       Four wheel instances
         roller_sign: +1 = rollers at +45° (FL, RR)
                      -1 = rollers at -45° (FR, RL)
       ================================================================ -->
  <xacro:macro name="wheels">
    <xacro:mecanum_wheel name="front_left"  x_sign=" 1" y_sign=" 1" roller_sign=" 1"/>
    <xacro:mecanum_wheel name="front_right" x_sign=" 1" y_sign="-1" roller_sign="-1"/>
    <xacro:mecanum_wheel name="rear_left"   x_sign="-1" y_sign=" 1" roller_sign="-1"/>
    <xacro:mecanum_wheel name="rear_right"  x_sign="-1" y_sign="-1" roller_sign=" 1"/>
  </xacro:macro>

</robot>
